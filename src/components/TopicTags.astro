---
/**
 * TopicTags.astro
 * ===============
 * Renders an article/post's topics as clickable chips under the banner.
 *
 * - Each chip carries `data-pagefind-filter="topic"`, so Pagefind indexes the
 *   topic as a real filter facet (used by the search bar's "Browse by tag" panel).
 * - Clicking a chip opens the top search bar filtered by that tag via the global
 *   `window.__openSearchWithTag` defined in scripts.js.
 */
interface Props {
  topics?: string[];
}

const { topics = [] } = Astro.props;
---

{
  topics.length > 0 && (
    <div class="topic topic-tags">
      <span class="topic-tags-label">Topics:</span>
      {topics.map((topic) => (
        <button
          type="button"
          class="topic-chip"
          data-pagefind-filter="topic"
          onclick={`window.__openSearchWithTag && window.__openSearchWithTag(${JSON.stringify(topic)})`}
        >
          {topic}
        </button>
      ))}
    </div>
  )
}

<style>
  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 5px;
  }

  .topic-tags-label {
    margin-right: 2px;
  }

  .topic-chip {
    font-family: inherit;
    font-size: 0.75em;
    line-height: 1.3;
    cursor: pointer;
    padding: 2px 7px;
    border-radius: 3px;
    border: 1px solid var(--box-border);
    background-color: var(--nav-bar-color);
    color: inherit;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .topic-chip:hover,
  .topic-chip:focus-visible {
    color: var(--highlight-dropdown-color);
    border-color: var(--highlight-dropdown-color);
    outline: none;
  }
</style>
