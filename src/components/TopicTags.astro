---
/**
 * TopicTags.astro
 * ===============
 * Renders an article/post's topics as a plain, comma-separated list under the
 * banner.
 *
 * - Each topic is wrapped in a span carrying `data-pagefind-filter="topic"`, so
 *   Pagefind still indexes the topic as a real filter facet (used by the top
 *   bar's tags dropdown chip cloud). The commas sit OUTSIDE those spans so they
 *   aren't part of the filter value.
 * - Non-interactive: browsing by tag happens through the tags icon in the top bar.
 */
interface Props {
  topics?: string[];
}

const { topics = [] } = Astro.props;
---

{
  topics.length > 0 && (
    <div class="topic topic-tags">
      <span class="topic-tags-label">Topics:</span>{" "}
      {topics.map((topic, i) => (
        <Fragment>
          <span data-pagefind-filter="topic">{topic}</span>{i < topics.length - 1 ? ", " : ""}
        </Fragment>
      ))}
    </div>
  )
}

<style>
  /* The shared .topic style is bold; keep only the "Topics:" label bold and
     render the tag list itself in normal weight. */
  .topic-tags {
    font-weight: normal;
  }
  .topic-tags-label {
    font-weight: bold;
  }
</style>
