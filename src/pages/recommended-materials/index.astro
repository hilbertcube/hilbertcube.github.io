---
/**
 * src/pages/recommended-materials/index.astro
 * ============================================
 * Resources page
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner.astro";
import HighlightsAndAttribute from "@components/HighlightsAndAttribute.astro";
import TableOfContents from "@components/TableOfContents.astro";
import MaterialCard from "@components/MaterialCard.astro";
---

<BaseLayout
  title="Materials"
  description="This is the material page"
  activeButton="Material-button"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/recommended-materials/resources-page.css" />
  </Fragment>

  <Fragment slot="sidebar">
    <TableOfContents
      items={[
        { label: "Books", href: "#books" },
        { label: "Read More", href: "#read-more" },
        { label: "Websites", href: "#websites" },
        { label: "Youtube Channels", href: "#youtube" },
      ]}
    />
    <div class="highlights-and-attribute">
      <HighlightsAndAttribute />
    </div>
  </Fragment>

  <Banner />

  <div class="content-grid">
    <header>
      <div class="topic">Materials - Math, CS, Websites, and more</div>
    </header>
    <h1 class="home-title">Recommended Materials</h1>

    <p>
      These are some resources that I think would serve as good learning
      materials.
    </p>

    <section>
      <h2 id="books" class="home-h3-headers">Books</h2>

      <div class="material-container">
        <MaterialCard
          title="C++ Templates: The Complete Guide"
          author="David Vandevoorde and Nicolai M. Josuttis"
          description="C++ is huge, and Templates is one of the crucial parts of it. Subjects covered: function and class templates, variadic templates, and much more."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/C-Templates-Complete-Guide-2nd/dp/0321714121" },
          ]}
          image="/recommended-materials/materials-images/templates.webp"
        />

        <MaterialCard
          title="C++ Concurrency in Action"
          author="Anthony Williams"
          description="There isn't much text-book resources out there relating to C++ multithreading. I'm currently reading this one, and I think it's pretty solid."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/C-Concurrency-Action-Practical-Multithreading/dp/1933988770" },
            { label: "Manning", href: "https://www.manning.com/books/c-plus-plus-concurrency-in-action" },
          ]}
          image="/recommended-materials/materials-images/concurrency.webp"
        />

        <MaterialCard
          title="A Complete Guide to Programming in C++"
          author="Ulla Kirch-Prinz and Peter Prinz"
          description="A good book for students to learn C++. This cover the language from the ground up, from basics to advanced."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Complete-Guide-Programming-Title-Demand/dp/0763718173" },
          ]}
          image="/recommended-materials/materials-images/cpp_complete.webp"
        />

        <MaterialCard
          title="Digital Image Processing"
          author="Rafael Gonzalez and Richard Woods"
          description="A good introduction to theoretical computer vision. I like the detail description of point, line, edge detection and the SIFT algorithm of this book."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Digital-Image-Processing-Rafael-Gonzalez/dp/0133356728" },
          ]}
          image="/recommended-materials/materials-images/digital_processing.webp"
        />

        <MaterialCard
          title="Data Structures and Algorithms in C++"
          author="Michael T. Goodrich, Roberto Tamassia, and David M. Mount"
          description="A classic for C++ DSA. The book cover standard stuff like arrays, vectors, linked lists, queues, stacks, priority queue, some trees, and graphs. There's also a paid Zybook version you can get for 60 bucks."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Data-Structures-Algorithms-Michael-Goodrich/dp/0470383275" },
            { label: "Wiley", href: "https://www.wiley.com/en-us/Data+Structures+and+Algorithms+in+C%2B%2B%2C+2nd+Edition-p-9780470383278" },
          ]}
          image="/recommended-materials/materials-images/cppdsa.webp"
        />

        <MaterialCard
          title="Introduction to Applied Partial Differential Equations"
          author="John M. Davis"
          description="The first book I used to learn PDEs. Very good treatment of eigenvalue and boundary-value problems."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Introduction-Applied-Partial-Differential-Equations/dp/1429275928" },
            { label: "Abebooks", href: "https://www.abebooks.com/9781429275927/Introduction-Applied-Partial-Differential-Equations-1429275928/plp" },
          ]}
          image="/recommended-materials/materials-images/pde2.webp"
        />

        <MaterialCard
          title="Applied Partial Differential Equations with Fourier Series and Boundary Value Problems"
          author="Richard Haberman"
          description="A more detailed treatment of PDEs for the undergraduate level, covering higher-dimensional PDE's, nonhomogeneous problems, green functions, and method of finite difference."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Differential-Equations-Boundary-Problems-Featured/dp/0321797051" },
          ]}
          image="/recommended-materials/materials-images/pde1.webp"
        />

        <MaterialCard
          title="Introduction to Electrodynamics"
          author="David J. Griffiths"
          description="If you truly want to learn Electrodynamics, this book is the one, written by none other than David J. Griffiths himself. Problems are very hard, but interesting."
          links={[
            { label: "Amazon", href: "https://www.amazon.com/Introduction-Electrodynamics-David-J-Griffiths/dp/1108420419" },
            { label: "Ebay", href: "https://www.ebay.com/itm/332769940414" },
            { label: "Abebooks", href: "https://www.abebooks.com/9781108420419/Introduction-Electrodynamics-Griffiths-David-J-1108420419/plp" },
          ]}
          image="/recommended-materials/materials-images/griffith_electrodymaics.webp"
        />
      </div>
    </section>

    <section>
      <h2 id="read-more" class="home-h3-headers">Read More</h2>
      <p>
        <b>What Every Programmer Should Know About Memory</b>:
        <a
          class="url"
          href="https://people.freebsd.org/~lstewart/articles/cpumemory.pdf"
          >link</a
        >
      </p>
      <p>
        <b>Ray Tracing in One Weekend</b>:
        <a
          class="url"
          href="https://raytracing.github.io/books/RayTracingInOneWeekend.html"
          >link</a
        >
      </p>
      <p>
        <b>Sunil Golwala's lecture note on classical mechanics - Caltech: </b>
        <a
          href="https://sites.astro.caltech.edu/~golwala/ph106ab/ph106ab_notes.pdf"
          class="url">link</a
        >
      </p>
      <p>
        <b>Riccardo Cristoferi's calculus of variations: </b>
        <a
          href="https://www.math.cmu.edu/cna/Publications/publications2016/papers/16-CNA-007.pdf"
          class="url">link</a
        >
      </p>
      <p>
        <b
          >Gabriel Nagy's Ordinary Differential Equations - University of
          Michigan:
        </b>
        <a
          href="https://users.math.msu.edu/users/gnagy/teaching/ode.pdf"
          class="url">link</a
        >
      </p>
    </section>

    <section>
      <h2 id="websites" class="home-h3-headers">Websites</h2>
      <p>
        <b>beltoforion: </b>
        <a href="https://beltoforion.de/de/" class="url">beltoforion.de</a>. One
        of my inspirations. Developed by Ingo Berg, the website focuses on a
        wide range of topics, ranging from programming, earth and space science,
        mathematics, and physics.
      </p>

      <p>
        <b>Ten Minute Physics: </b>
        <a
          href="https://matthias-research.github.io/pages/tenMinutePhysics/index.html"
          class="url">link</a
        >. Cool, complex physics simulation using only HTML and Javascript. This
        is a website created to accompany the youtube channel <a
          href="https://www.youtube.com/@tenminutephysics"
          class="url">Ten Minute Physics.</a
        >
      </p>

      <p>
        <b>scipython: </b>
        <a href="https://scipython.com/" class="url">scipython.com</a>. Created
        by the author of <a
          href="https://www.cambridge.org/sj/universitypress/subjects/physics/mathematical-methods/learning-scientific-programming-python-2nd-edition?format=PB"
          class="url">Learning Scientific Programming with Python</a
        >, Christian Hill. Resources for learning Python simulation and
        scientific programming.
      </p>

      <p>
        <b>Romanian Mathematical Magazine: </b>
        <a href="https://www.ssmrmh.ro/" class="url">ssmrmh.ro</a>. Very cool
        math problems.
      </p>

      <p>
        <b>learncpp: </b>
        <a href="https://learncpp.com/" class="url">learncpp.com</a>. A good
        website for learning C++ from start to end.
      </p>
    </section>

    <section>
      <h2 id="youtube" class="home-h3-headers">Youtube Channels</h2>

      <p>
        <b>Mathematics: </b>
        <a href="https://www.youtube.com/@3blue1brown" class="url"
          >3Blue1Brown</a
        >,
        <a href="https://www.youtube.com/@Mathologer" class="url">Mathologer</a
        >,
        <a href="https://www.youtube.com/@MichaelPennMath" class="url"
          >Michael Penn</a
        >,
        <a href="https://www.youtube.com/@morphocular" class="url"
          >Morphocular</a
        >,
        <a href="https://www.youtube.com/@maths_505" class="url">Maths 505</a>,
        <a href="https://www.youtube.com/@Aleph0" class="url">Aleph 0</a>,
        <a href="https://www.youtube.com/@CreativeMathProblems" class="url"
          >Creative Math Problems</a
        >,
        <a href="https://www.youtube.com/@DrBarker" class="url">Dr Barker</a>,
        <a href="https://www.youtube.com/@DrTrefor" class="url"
          >Dr. Trefor Bazett</a
        >,
        <a href="https://www.youtube.com/@EpsilonDeltaMain" class="url"
          >EpsilonDelta</a
        >,
        <a href="https://www.youtube.com/@richarde.borcherds7998" class="url"
          >Richard E Borcherds</a
        >,
        <a href="https://www.youtube.com/@mathemaniac" class="url"
          >Mathemaniac</a
        >
      </p>
      <p>
        <b>Computer Science: </b>
        <a href="https://www.youtube.com/@Computerphile" class="url"
          >Computerphile</a
        >,
        <a href="https://www.youtube.com/@Errichto" class="url"
          >Errichto Algorithms</a
        >,
        <a href="https://www.youtube.com/@SheafificationOfG" class="url"
          >Sheafification of G</a
        >
      </p>
      <p>
        <b>Low-level Programming:</b>
        <a href="https://www.youtube.com/@TheCherno" class="url">The Cherno</a>,
        <a href="https://www.youtube.com/@LowLevelTV" class="url">Low Level</a>,
        <a href="https://www.youtube.com/@TsodingDaily" class="url"
          >Tscoding Daily</a
        >,
        <a href="https://www.youtube.com/@CoreDumpped" class="url"
          >Core Dumped</a
        >,
        <a href="https://www.youtube.com/@AngeTheGreat" class="url"
          >Ange The Great</a
        >,
        <a href="https://www.youtube.com/@lauriewired" class="url"
          >Laurie Wired</a
        >,
        <a href="https://www.youtube.com/@artfulbytes" class="url"
          >Artful Bytes</a
        >
      </p>
      <p>
        <b>Computer Simulations and Numerical Computation: </b>
        <a href="https://www.youtube.com/@PezzzasWork" class="url"
          >Pezzza's Work</a
        >,
        <a href="https://www.youtube.com/@Eigensteve" class="url"
          >Steve Brunton</a
        >,
        <a href="https://www.youtube.com/@MrPSolver" class="url">Mr. P Solver</a
        >,
        <a href="https://www.youtube.com/@AngeTheGreat" class="url"
          >AngeTheGreat</a
        >,
        <a href="https://www.youtube.com/@ArtemKirsanov" class="url"
          >Artem Kirsanov</a
        >
      </p>
      <p>
        <b>Fun Programming: </b>
        <a href="https://www.youtube.com/@SebastianLague" class="url"
          >Sebastian Lague</a
        >,
        <a href="https://www.youtube.com/@CodeBullet" class="url">Code Bullet</a
        >,
        <a href="https://www.youtube.com/@CodeParade" class="url">Code Parade</a
        >
      </p>
      <p>
        <b>Web Development: </b>
        <a href="https://www.youtube.com/@TheCoderCoder" class="url"
          >Coder Coder</a
        >,
        <a href="https://www.youtube.com/@coding2go" class="url">Coding2GO</a>
      </p>
      <p>
        <b>Physics: </b>
        <a href="https://www.youtube.com/@DrBenYelverton" class="url"
          >Dr Ben Yelverton</a
        >,
        <a href="https://www.youtube.com/@jkzero" class="url"
          >Dr. Jorge S. Diaz</a
        >
      </p>

      <h3>Some of my favorite videos:</h3>
      <div class="fav-vids">
        <div style="display: flex; justify-content: center; margin-top: 30px;">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/C8YtdC8mxTU?si=3NnFrhjh5LWPf7O_"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 30px;">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/th5A6ZQ28pE?si=ZwiUikHlGoBaJm5b"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 30px;">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/KzT9I1d-LlQ?si=0QMxlKCaT55RBPx3"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
      </div>
    </section>
  </div>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/canvas-banner.js"></script>
  </Fragment>
</BaseLayout>
