---
/**
 * src/pages/articles/moment-of-inertia/index.astro
 * =================================================
 * Article: Slightly More Interesting Inertia Problems
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import HighlightsAndAttribute from "@components/HighlightsAndAttribute.astro";
import TableOfContents from "@components/TableOfContents.astro";
import fs from "node:fs";
import path from "node:path";

const data = JSON.parse(
  fs.readFileSync(path.resolve("public/assets/json/articles.json"), "utf-8"),
);
const slug = Astro.url.pathname.replace(/\/$/, "");
const meta = data.articles.find((a: any) => a.link.replace(/\/$/, "") === slug);
---

<BaseLayout
  title="Article - Moment of Inertia"
  description="Slightly More Interesting Inertia Problems"
  keywords="Wave equation, python, eigenvalue, boundary conditions"
>
  <Fragment slot="head">
    <style>
      .front-img {
        display: block;
        width: 100%;
        border-radius: 10px;
        height: auto;
        margin: auto;
      }
    </style>
  </Fragment>

  <Fragment slot="sidebar">
    <TableOfContents
      items={[
        { label: "Introduction" },
        { label: "Appendix", href: "#Appendix" },
        { label: "References", href: "#References" },
      ]}
    />
    <div class="highlights-and-attribute">
      <HighlightsAndAttribute />
    </div>
  </Fragment>

  <div class="mathjax-definition">
    \[ \newcommand&#123;\lbrac&#125;&#123;\left(&#125;
    \newcommand&#123;\rbrac&#125;&#123;\right)&#125; \]
  </div>

  <div class="content-grid">
    <header>
      <div class="topic">Topics: {meta.topics.join(", ")}</div>
      <h1 class="title">{meta.title}</h1>
      <div class="date">{meta.date ? `Updated ${meta.date}` : ""}</div>
      <figure style="margin: 0;">
        <img class="front-img" src="#" alt="image" />
      </figure>
    </header>

    <div class="Quote">
      <div class="Quote-content">&#8220;Some Quote.&#8221;</div>
      <div class="Author">- Author</div>
    </div>

    <h2 id="Introduction">Introduction</h2>
  </div>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/blogpage-setting.js"></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.28.0/prism.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.28.0/components/prism-python.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.28.0/plugins/line-numbers/prism-line-numbers.min.js"
    ></script>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"
      async></script>
  </Fragment>
</BaseLayout>
