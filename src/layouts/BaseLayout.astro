---
/**
 * BaseLayout.astro
 * ================
 * Shared layout for all pages.
 */
import TopBar from "@components/TopBar.astro";
import ShareButton from "@components/ShareButton.astro";
import Logo from "@components/Logo.astro";
import Footer from "@components/Footer.astro";
import HighlightsAndAttribute from "@components/HighlightsAndAttribute.astro";
import ArticleCards from "@components/ArticleCards.astro";


// Vite bundles all @import statements into one minified CSS file
import "../assets/css/main.css";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  /** ID of the nav button to highlight, e.g. "Home-button" */
  activeButton?: string;
}

const {
  title,
  description = "",
  keywords = "math, physics, programming, coding, computer science, computer simulation",
  activeButton = "",
} = Astro.props;

const isArticle = Astro.url.pathname.startsWith("/articles/");
const tex = String.raw;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Analytics -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-00W722FWP2"
      is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-00W722FWP2");
    </script>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title} - neumanncondition</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="subject" content="Mathematics, Physics, and Computer Science Articles, Posts, Tutorials, and more" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Don Le, ledongduu@gmail.com" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Preconnect to third-party origins -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.28.0/plugins/line-numbers/prism-line-numbers.min.css" />

    <!-- Active nav button highlighting -->
    {
      activeButton && (
        <style
          set:html={`
      #${activeButton} {
        font-weight: bold;
        text-decoration: underline;
      }
    `}
        />
      )
    }

    <!-- Page-specific head content (extra styles, meta, etc.) -->
    <slot name="head" />

    <!-- Apply dark mode before first paint to prevent flash -->
    <script is:inline>
      if (localStorage.getItem("mode") === "dark") {
        document.documentElement.classList.add("dark-mode");
      }
    </script>
  </head>

  <body class="light-mode">
    <TopBar />
    <ShareButton />

    <nav class="navbar" id="navbar">
      <div class="logo-and-side-nav">
        <Logo />
      </div>
      <!-- Sidebar: use the "sidebar" slot to override (e.g. TOC on about/article pages) -->
      <slot name="sidebar">
        <div class="highlights-and-attribute">
          <HighlightsAndAttribute />
        </div>
      </slot>
    </nav>

    <main class="general-wrapper" data-pagefind-body>
      <!-- Page-specific content goes here -->
      <slot />

      {
        isArticle && (
          <div class="content-grid" style="margin-top: -100px" data-pagefind-ignore>
            <section>
              <h2>More Articles</h2>
              <ArticleCards
                count={4}
                showDetails={true}
                shuffle={true}
                excludePath={Astro.url.pathname.replace(/\/$/, "")}
              />
            </section>
          </div>
        )
      }

      <footer data-pagefind-ignore>
        <Footer />
      </footer>
    </main>

    <script is:inline src="/assets/js/scripts.js"></script>

    <!-- Pagefind on-page highlight (via ?pagefind-highlight=…). The script only
         marks matches; it doesn't scroll — so we scroll to the first match,
         preferring one inside the linked #section. No-ops without the index (dev). -->
    <script is:inline type="module">
      import("/pagefind/pagefind-highlight.js")
        .then((m) => {
          const Highlighter = m.default;

          // Scroll to the first match, preferring one inside section `id`.
          function scrollToMatch(id) {
            let tries = 0;
            (function poll() {
              const marks = document.querySelectorAll("mark.pagefind-highlight");
              if (!marks.length) {
                if (tries++ < 25) setTimeout(poll, 60);
                return;
              }
              let target = null;
              if (id) {
                const sec = document.getElementById(id);
                if (sec) {
                  for (const mk of marks) {
                    if (
                      sec.contains(mk) ||
                      sec.compareDocumentPosition(mk) &
                        Node.DOCUMENT_POSITION_FOLLOWING
                    ) {
                      target = mk;
                      break;
                    }
                  }
                }
              }
              (target || marks[0]).scrollIntoView({
                block: "center",
                behavior: "smooth",
              });
            })();
          }

          // Initial run: page opened with ?pagefind-highlight=…
          new Highlighter({ addStyles: false });
          const hash = decodeURIComponent((location.hash || "").slice(1));
          scrollToMatch(hash);

          // Late-loading images can shift the target after the first scroll, so
          // re-scroll once the page has fully loaded — unless the reader has
          // already taken over scrolling.
          if (document.readyState !== "complete") {
            let userMoved = false;
            const flag = () => (userMoved = true);
            ["wheel", "touchstart", "keydown", "pointerdown"].forEach((e) =>
              addEventListener(e, flag, { once: true, passive: true }),
            );
            addEventListener(
              "load",
              () => {
                if (!userMoved) scrollToMatch(hash);
              },
              { once: true },
            );
          }

          // Same-page search navigation: re-highlight for a new query and scroll,
          // without a page reload / new tab.
          window.__pagefindGoInPage = function (url) {
            const u = new URL(url, location.href);
            history.replaceState(null, "", u.pathname + u.search + u.hash);
            document.querySelectorAll("mark.pagefind-highlight").forEach((mk) => {
              const p = mk.parentNode;
              p.replaceChild(document.createTextNode(mk.textContent), mk);
              p.normalize();
            });
            new Highlighter({ addStyles: false });
            scrollToMatch(decodeURIComponent((u.hash || "").slice(1)));
          };
        })
        .catch(() => {});
    </script>

    <!-- Additional page-specific scripts -->
    <slot name="scripts" />
  </body>
</html>
